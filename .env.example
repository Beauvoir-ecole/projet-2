# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.

# Flask secret key (used for sessions). Generate a random one:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex

# Admin credentials (used for the /admin login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Postgres URL — get this from https://neon.tech (free tier).
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# MongoDB URL — get this from https://mongodb.com/atlas (free tier).
# Format: mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=projet_2
